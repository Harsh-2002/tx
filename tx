EOF
}

# Detailed help with examples for a single command
cmd_help_detail() {
    case "$1" in
        new)
            cat <<EOF
${BOLD}tx new${RESET} [name]
  Create a new tmux session.
  If no name given, auto-generates one.

  ${DIM}Examples:${RESET}
    ${CYAN}tx new${RESET}           → new session with auto-generated name
    ${CYAN}tx new work${RESET}      → new session named "work"
EOF
            ;;
        ls)
            cat <<EOF
${BOLD}tx ls${RESET}
  List all tmux sessions.

  ${DIM}Example:${RESET}
    ${CYAN}tx ls${RESET}
EOF
            ;;
        a|attach)
            cat <<EOF
${BOLD}tx a${RESET} [name]
  Attach to a session. If only one session exists, attaches
  automatically. If multiple, lists them.

  ${DIM}Examples:${RESET}
    ${CYAN}tx a${RESET}             → attach to the only session
    ${CYAN}tx a work${RESET}        → attach to session "work"
EOF
            ;;
        detach)
            cat <<EOF
${BOLD}tx detach${RESET}
  Detach from the current tmux session.
  Must be inside tmux.
EOF
            ;;
        kill)
            cat <<EOF
${BOLD}tx kill${RESET} [name]
  Kill a session. If inside tmux with no name, kills current session.

  ${DIM}Examples:${RESET}
    ${CYAN}tx kill work${RESET}     → kill session "work"
    ${CYAN}tx kill${RESET}          → kill current session (inside tmux)
EOF
            ;;
        split)
            cat <<EOF
${BOLD}tx split${RESET}
  Split the current pane side-by-side (left/right).
  Must be inside tmux.
EOF
            ;;
        vsplit)
            cat <<EOF
${BOLD}tx vsplit${RESET}
  Split the current pane top/bottom.
  Must be inside tmux.
EOF
            ;;
        pane)
            cat <<EOF
${BOLD}tx pane${RESET} <n>
  Switch to pane N. Panes are 1-indexed (1, 2, 3...).

  ${DIM}Examples:${RESET}
    ${CYAN}tx pane 1${RESET}        → switch to first pane
    ${CYAN}tx pane 3${RESET}        → switch to third pane
EOF
            ;;
        close)
            cat <<EOF
${BOLD}tx close${RESET}
  Close the current pane. Must be inside tmux.
EOF
            ;;
        resize)
            cat <<EOF
${BOLD}tx resize${RESET} <direction> [amount]
  Resize the current pane. Direction: left, right, up, down.
  Amount defaults to 5 cells.

  Use ${CYAN}tx resize even${RESET} to rebalance all panes to equal size.

  ${DIM}Examples:${RESET}
    ${CYAN}tx resize left${RESET}       → shrink pane 5 cells left
    ${CYAN}tx resize right 10${RESET}   → grow pane 10 cells right
    ${CYAN}tx resize up 3${RESET}       → grow pane 3 cells up
    ${CYAN}tx resize even${RESET}       → make all panes equal size
EOF
            ;;
        swap)
            cat <<EOF
${BOLD}tx swap${RESET} <n>
  Swap the current pane with pane N (1-indexed).

  ${DIM}Example:${RESET}
    ${CYAN}tx swap 2${RESET}        → swap current pane with pane 2
EOF
            ;;
        full)
            cat <<EOF
${BOLD}tx full${RESET}
  Toggle fullscreen (zoom) on the current pane.
  Run again to restore.
EOF
            ;;
        send)
            cat <<EOF
${BOLD}tx send${RESET} <n> '<command>'
  Send a command to pane N (1-indexed).

  ${DIM}Examples:${RESET}
    ${CYAN}tx send 1 'ls -la'${RESET}       → run ls in pane 1
    ${CYAN}tx send 2 'npm start'${RESET}    → run npm start in pane 2
EOF
            ;;
        send-all)
            cat <<EOF
${BOLD}tx send-all${RESET} '<command>'
  Broadcast a command to every pane in the current window.
  Must be inside tmux.

  ${DIM}Examples:${RESET}
    ${CYAN}tx send-all 'clear'${RESET}            → clear all panes
    ${CYAN}tx send-all 'git pull'${RESET}          → git pull in all panes
    ${CYAN}tx send-all 'cd /var/log'${RESET}       → change dir in all panes
EOF
            ;;
        layout)
            cat <<EOF
${BOLD}tx layout${RESET} <count> [-v] [grid] [commands...]
  Create multiple panes with a layout.

  ${DIM}Directions:${RESET}
    (default)    Horizontal columns (side-by-side)
    -v           Vertical rows (stacked)
    grid         Tiled grid

  If not in tmux, creates a new session automatically.
  Commands after the count/flags are sent to each pane.

  ${DIM}Examples:${RESET}
    ${CYAN}tx layout 2${RESET}                              → 2 columns
    ${CYAN}tx layout 3 -v${RESET}                           → 3 rows
    ${CYAN}tx layout 4 grid${RESET}                         → 2x2 grid
    ${CYAN}tx layout 3 'vim' 'npm run dev' 'htop'${RESET}   → 3 columns with commands
    ${CYAN}tx layout 3 -v 'cmd1' 'cmd2' 'cmd3'${RESET}     → 3 rows with commands
EOF
            ;;
        save)
            cat <<EOF
${BOLD}tx save${RESET} [name]
  Save the current window's layout, pane directories, and
  running commands. Saves to ~/.config/tx/saves/.

  If no name given, uses the current session name.

  ${DIM}Examples:${RESET}
    ${CYAN}tx save${RESET}              → save as current session name
    ${CYAN}tx save backend${RESET}      → save as "backend"
EOF
            ;;
        load)
            cat <<EOF
${BOLD}tx load${RESET} <name>
  Restore a saved layout. Recreates the exact pane arrangement,
  cd's into each pane's directory, and reruns saved commands.

  Outside tmux: creates a new session.
  Inside tmux: creates a new window.

  ${DIM}Examples:${RESET}
    ${CYAN}tx load backend${RESET}      → restore "backend" layout
    ${CYAN}tx load${RESET}              → list available saves
EOF
            ;;
        saves)
            cat <<EOF
${BOLD}tx saves${RESET}
  List all saved layouts with pane details.

  ${DIM}Example:${RESET}
    ${CYAN}tx saves${RESET}
EOF
            ;;
        rm)
            cat <<EOF
${BOLD}tx rm${RESET} <name>
  Delete a saved layout.

  ${DIM}Example:${RESET}
    ${CYAN}tx rm backend${RESET}        → delete "backend" save
EOF
            ;;
        win)
            cat <<EOF
${BOLD}tx win${RESET} [name]
  Create a new window. Auto-names if no name given.

  ${DIM}Examples:${RESET}
    ${CYAN}tx win${RESET}           → new window
    ${CYAN}tx win logs${RESET}      → new window named "logs"
EOF
            ;;
        wins)
            cat <<EOF
${BOLD}tx wins${RESET}
  List all windows in the current session.
EOF
            ;;
        next)
            cat <<EOF
${BOLD}tx next${RESET}
  Switch to the next window.
EOF
            ;;
        prev)
            cat <<EOF
${BOLD}tx prev${RESET}
  Switch to the previous window.
EOF
            ;;
        rename)
            cat <<EOF
${BOLD}tx rename${RESET} <name>
  Rename the current window.

  ${DIM}Example:${RESET}
    ${CYAN}tx rename editor${RESET}
EOF
            ;;
        update)
            cat <<EOF
${BOLD}tx update${RESET}
  Update tx to the latest version from GitHub.
  Requires curl or wget. May need sudo if installed in /usr/local/bin.

  ${DIM}Example:${RESET}
    ${CYAN}tx update${RESET}
EOF
            ;;
        *)
            die "unknown command '$1' — run 'tx help' for all commands"
            ;;
    esac
}

# Main dispatch

# version/update/help don't need tmux
case "${1:-}" in
    --version|-v) cmd_version; exit 0 ;;
    version)      cmd_version; exit 0 ;;
    update)       cmd_update; exit 0 ;;
    help|-h|--help) ;;
    *)            ensure_tmux ;;
esac

case "${1:-}" in
    "")       cmd_default ;;
    new)      shift; cmd_new "$@" ;;
    ls)       shift; cmd_ls ;;
    a)        shift; cmd_attach "$@" ;;
    attach)   shift; cmd_attach "$@" ;;
    detach)   shift; cmd_detach ;;
    kill)     shift; cmd_kill "$@" ;;
    split)    shift; cmd_split ;;
    vsplit)   shift; cmd_vsplit ;;
    pane)     shift; cmd_pane "$@" ;;
    close)    shift; cmd_close ;;
    resize)   shift; cmd_resize "$@" ;;
    swap)     shift; cmd_swap "$@" ;;
    full)     shift; cmd_full ;;
    send)     shift; cmd_send "$@" ;;
    send-all) shift; cmd_send_all "$@" ;;
    layout)   shift; cmd_layout "$@" ;;
    save)     shift; cmd_save "$@" ;;
    load)     shift; cmd_load "$@" ;;
    saves)    shift; cmd_saves ;;
    rm)       shift; cmd_rm "$@" ;;
    win)      shift; cmd_win "$@" ;;
    wins)     shift; cmd_wins ;;
    next)     shift; cmd_next ;;
    prev)     shift; cmd_prev ;;
    rename)   shift; cmd_rename "$@" ;;
    help)     shift; cmd_help "$@" ;;
    -h)       cmd_help ;;
    --help)   cmd_help ;;
    *)        die "unknown command '$1' — run 'tx help' for all commands" ;;
esac
