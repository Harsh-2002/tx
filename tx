#!/bin/sh
# tx — a dead-simple tmux wrapper
# https://github.com/Harsh-2002/tx
# MIT License

set -e

TX_VERSION="0.7.0"
TX_SAVE_DIR="${TX_SAVE_DIR:-$HOME/.config/tx/saves}"

# Color setup — auto-detects terminal support, no colors when piped
setup_colors() {
    if [ -t 1 ] && [ "${TERM:-}" != "dumb" ]; then
        RED=$(printf '\033[31m')
        GREEN=$(printf '\033[32m')
        CYAN=$(printf '\033[36m')
        BOLD=$(printf '\033[1m')
        DIM=$(printf '\033[2m')
        RESET=$(printf '\033[0m')
    else
        RED="" GREEN="" CYAN="" BOLD="" DIM="" RESET=""
    fi
}
setup_colors

# Helpers

ensure_tmux() {
    command -v tmux >/dev/null 2>&1 || {
        printf '%stx:%s tmux is not installed\n' "$RED" "$RESET" >&2
        exit 1
    }
}

in_tmux() {
    [ -n "$TMUX" ]
}

auto_name() {
    # Use current directory name, sanitized for tmux
    _dir=$(basename "$PWD" 2>/dev/null)
    # Remove characters tmux doesn't like in session names
    _dir=$(echo "$_dir" | tr -d '.:')
    # Fallback chain: dir name → "main" → tx-<animal>
    if [ -n "$_dir" ] && ! tmux has-session -t "$_dir" 2>/dev/null; then
        echo "$_dir"
    elif ! tmux has-session -t "main" 2>/dev/null; then
        echo "main"
    else
        _names="fox owl lynx puma yak emu cobra raven otter panda hawk viper falcon wolf bear tiger robin finch crane heron dove moose bison eagle orca"
        _pick=$(echo "$_names" | tr ' ' '\n' | awk "BEGIN{srand($$+PROCINFO[\"pid\"])}{a[NR]=\$0}END{print a[int(rand()*NR)+1]}" 2>/dev/null || echo "$_names" | tr ' ' '\n' | awk "BEGIN{srand($$)}{a[NR]=\$0}END{print a[int(rand()*NR)+1]}")
        _name="tx-${_pick}"
        # If that name is also taken, append a digit
        if tmux has-session -t "$_name" 2>/dev/null; then
            _i=2
            while tmux has-session -t "${_name}${_i}" 2>/dev/null; do
                _i=$(( _i + 1 ))
            done
            _name="${_name}${_i}"
        fi
        echo "$_name"
    fi
}

# Convert 1-indexed pane number to tmux's 0-indexed
pane_index() {
    echo $(( $1 - 1 ))
}

die() {
    printf '%stx:%s %s\n' "$RED" "$RESET" "$*" >&2
    exit 1
}

# Session commands

# Smart default: status / create / attach / list depending on context
cmd_default() {
    if in_tmux; then
        _sess=$(tmux display-message -p '#S')
        _wins=$(tmux list-windows | wc -l | tr -d ' ')
        _panes=$(tmux list-panes | wc -l | tr -d ' ')
        printf '%sSession:%s %s%s%s\n' "$BOLD" "$RESET" "$CYAN" "$_sess" "$RESET"
        printf '%sWindows:%s %s\n' "$BOLD" "$RESET" "$_wins"
        printf '%sPanes:%s   %s\n' "$BOLD" "$RESET" "$_panes"
        echo ""
        tmux list-panes -F '#{pane_index}|#{pane_current_command}|#{pane_current_path}' | while IFS='|' read -r _i _cmd _path; do
            _human=$(( _i + 1 ))
            printf '  %s%s%s  %-12s  %s%s%s\n' "$CYAN" "$_human" "$RESET" "$_cmd" "$DIM" "$_path" "$RESET"
        done
        echo ""
        tmux list-windows -F '#I|#W|#{window_active}' | while IFS='|' read -r _i _w _a; do
            if [ "$_a" = "1" ]; then
                printf '  %s%s: %s%s (active)\n' "$CYAN" "$_i" "$_w" "$RESET"
            else
                printf '  %s: %s\n' "$_i" "$_w"
            fi
        done
    else
        _count=$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')
        if [ "$_count" -eq 0 ] 2>/dev/null; then
            tmux new-session -s "$(auto_name)"
        elif [ "$_count" -eq 1 ]; then
            _name=$(tmux list-sessions -F '#S')
            tmux attach-session -t "$_name"
        else
            printf '%sSessions:%s\n' "$BOLD" "$RESET"
            tmux list-sessions -F '#S|#{session_windows}' | while IFS='|' read -r _s _w; do
                printf '  %s%s%s (%s windows)\n' "$CYAN" "$_s" "$RESET" "$_w"
            done
            echo ""
            printf 'Attach with: %stx a <name>%s\n' "$CYAN" "$RESET"
        fi
    fi
}

# Create a new session, auto-names if no name given
cmd_new() {
    _name="${1:-$(auto_name)}"
    if in_tmux; then
        tmux new-session -d -s "$_name"
        tmux switch-client -t "$_name"
    else
        tmux new-session -s "$_name"
    fi
}

# List all active sessions
cmd_ls() {
    if ! tmux list-sessions >/dev/null 2>&1; then
        echo "No sessions."
        return
    fi
    tmux list-sessions -F '#S|#{session_windows}|#{session_created_string}' | while IFS='|' read -r _s _w _c; do
        printf '  %s%s%s (%s windows, created %s)\n' "$CYAN" "$_s" "$RESET" "$_w" "$_c"
    done
}

# Attach to a session by name, auto-attaches if only one exists
cmd_attach() {
    if [ -n "$1" ]; then
        tmux attach-session -t "$1" 2>/dev/null || die "session '$1' not found"
    else
        _count=$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')
        if [ "$_count" -eq 0 ] 2>/dev/null; then
            die "no sessions to attach to"
        elif [ "$_count" -eq 1 ]; then
            tmux attach-session
        else
            printf '%sMultiple sessions — specify one:%s\n' "$BOLD" "$RESET"
            tmux list-sessions -F '#S' | while read -r _s; do
                printf '  %s%s%s\n' "$CYAN" "$_s" "$RESET"
            done
            echo ""
            printf 'Usage: %stx a <name>%s\n' "$CYAN" "$RESET"
        fi
    fi
}

# Detach from the current session
cmd_detach() {
    in_tmux || die "not in a tmux session"
    tmux detach-client
}

# Kill a session by name, or the current one if inside tmux
cmd_kill() {
    if [ -n "$1" ]; then
        tmux kill-session -t "$1" 2>/dev/null || die "session '$1' not found"
    else
        if in_tmux; then
            tmux kill-session
        else
            die "specify a session name: tx kill <name>"
        fi
    fi
}

# Pane commands

# Split the current pane side-by-side (left/right)
cmd_split() {
    in_tmux || die "not in tmux — start a session first: tx new"
    tmux split-window -h
}

# Split the current pane top/bottom
cmd_vsplit() {
    in_tmux || die "not in tmux — start a session first: tx new"
    tmux split-window -v
}

# Switch focus to pane N (1-indexed)
cmd_pane() {
    [ -n "$1" ] || die "usage: tx pane <number>"
    in_tmux || die "not in tmux"
    _idx=$(pane_index "$1")
    tmux select-pane -t "$_idx" 2>/dev/null || die "pane $1 does not exist"
}

# Close the current pane
cmd_close() {
    in_tmux || die "not in tmux"
    tmux kill-pane
}

# Resize the current pane or rebalance all panes
cmd_resize() {
    [ -n "$1" ] || die "usage: tx resize <left|right|up|down|even> [amount]"
    in_tmux || die "not in tmux"
    _dir="$1"
    _amount="${2:-5}"
    case "$_dir" in
        left)  tmux resize-pane -L "$_amount" ;;
        right) tmux resize-pane -R "$_amount" ;;
        up)    tmux resize-pane -U "$_amount" ;;
        down)  tmux resize-pane -D "$_amount" ;;
        even)
            # Detect layout direction from pane positions
            _tops=$(tmux list-panes -F '#{pane_top}' | sort -u | wc -l | tr -d ' ')
            _lefts=$(tmux list-panes -F '#{pane_left}' | sort -u | wc -l | tr -d ' ')
            if [ "$_tops" -eq 1 ]; then
                # All panes on same row → side by side
                tmux select-layout even-horizontal
            elif [ "$_lefts" -eq 1 ]; then
                # All panes in same column → stacked
                tmux select-layout even-vertical
            else
                # Mixed arrangement → tiled
                tmux select-layout tiled
            fi
            ;;
        *)     die "usage: tx resize <left|right|up|down|even> [amount]" ;;
    esac
}

# Swap the current pane with pane N (1-indexed)
cmd_swap() {
    [ -n "$1" ] || die "usage: tx swap <pane-number>"
    in_tmux || die "not in tmux"
    _idx=$(pane_index "$1")
    tmux swap-pane -t "$_idx" 2>/dev/null || die "pane $1 does not exist"
}

# Toggle zoom (fullscreen) on the current pane
cmd_full() {
    in_tmux || die "not in tmux"
    tmux resize-pane -Z
}

# Send command to a pane

# Send a shell command to pane N (1-indexed)
cmd_send() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        die "usage: tx send <pane-number> '<command>'"
    fi
    _idx=$(pane_index "$1")
    shift
    _cmd="$*"
    if in_tmux; then
        tmux send-keys -t "$_idx" "$_cmd" Enter
    else
        tmux send-keys -t "$_idx" "$_cmd" Enter 2>/dev/null || die "cannot send — no active session or pane not found"
    fi
}

# Send a command to all panes in the current window
cmd_send_all() {
    [ -n "$1" ] || die "usage: tx send-all '<command>'"
    in_tmux || die "not in tmux"
    _cmd="$*"
    tmux list-panes -F '#{pane_index}' | while read -r _idx; do
        tmux send-keys -t "$_idx" "$_cmd" Enter
    done
}

# Layout command

# Create N panes with an even layout and optionally run a command in each.
# Rebalances after each split so any pane count works reliably.
# If not inside tmux, creates a new session automatically.
cmd_layout() {
    [ -n "$1" ] || die "usage: tx layout <count> [-v] [grid] [commands...]"

    _count="$1"
    shift

    case "$_count" in
        ''|*[!0-9]*) die "pane count must be a number" ;;
    esac
    [ "$_count" -ge 1 ] || die "pane count must be at least 1"

    _direction="h"
    _layout_type="even"

    # Separate flags (-v, grid) from command strings
    _new_args=""
    for _arg in "$@"; do
        case "$_arg" in
            -v)   _direction="v" ;;
            grid) _layout_type="grid" ;;
            *)    _new_args="${_new_args} \"$(echo "$_arg" | sed 's/"/\\"/g')\"" ;;
        esac
    done
    eval "set -- $_new_args"

    # Map flags to tmux layout name
    if [ "$_layout_type" = "grid" ]; then
        _tmux_layout="tiled"
    elif [ "$_direction" = "v" ]; then
        _tmux_layout="even-vertical"
    else
        _tmux_layout="even-horizontal"
    fi

    # Determine split direction flag
    if [ "$_direction" = "v" ] && [ "$_layout_type" = "even" ]; then
        _split_flag="-v"
    else
        _split_flag="-h"
    fi

    if ! in_tmux; then
        _sess="layout-$(date +%s | tail -c 5)"
        tmux new-session -d -s "$_sess"

        _i=1
        while [ "$_i" -lt "$_count" ]; do
            tmux split-window "$_split_flag" -t "$_sess"
            tmux select-layout -t "$_sess" "$_tmux_layout"
            _i=$(( _i + 1 ))
        done

        _pane_idx=0
        for _c in "$@"; do
            tmux send-keys -t "${_sess}:0.${_pane_idx}" "$_c" Enter
            _pane_idx=$(( _pane_idx + 1 ))
        done

        tmux attach-session -t "$_sess"
    else
        _i=1
        while [ "$_i" -lt "$_count" ]; do
            tmux split-window "$_split_flag"
            tmux select-layout "$_tmux_layout"
            _i=$(( _i + 1 ))
        done

        _pane_idx=0
        for _c in "$@"; do
            tmux send-keys -t "$_pane_idx" "$_c" Enter
            _pane_idx=$(( _pane_idx + 1 ))
        done

        tmux select-pane -t 0
    fi
}

# Save and load commands

# Save the current window's layout, directories, and running commands
cmd_save() {
    in_tmux || die "not in tmux — nothing to save"
    _name="${1:-$(tmux display-message -p '#S')}"
    mkdir -p "$TX_SAVE_DIR"
    _file="${TX_SAVE_DIR}/${_name}"

    # First line: tmux layout string (captures exact pane arrangement)
    tmux display-message -p '#{window_layout}' > "$_file"

    # Remaining lines: one per pane as dir|command
    _pane_count=$(tmux list-panes | wc -l | tr -d ' ')
    _p=0
    while [ "$_p" -lt "$_pane_count" ]; do
        _dir=$(tmux display-message -p -t "$_p" '#{pane_current_path}')
        _cur=$(tmux display-message -p -t "$_p" '#{pane_current_command}')
        _pid=$(tmux display-message -p -t "$_p" '#{pane_pid}')

        _cmd=""
        # If pane is at a shell prompt, save no command
        case "$_cur" in
            bash|zsh|sh|ash|dash|fish|ksh|csh|tcsh|-bash|-zsh|-sh) ;;
            *)
                # Try to get full command line of the running process
                _cmd=$(ps -eo pid,ppid,args 2>/dev/null | awk -v p="$_pid" '$2==p {$1=$2=""; sub(/^[[:space:]]+/, ""); print; exit}')
                [ -z "$_cmd" ] && _cmd="$_cur"
                ;;
        esac

        echo "${_dir}|${_cmd}" >> "$_file"
        _p=$(( _p + 1 ))
    done

    printf '  %s✓%s Saved %s%s%s (%s panes)\n' "$GREEN" "$RESET" "$BOLD" "$_name" "$RESET" "$_pane_count"
}

# Load a saved layout into a new session or window
cmd_load() {
    if [ -z "$1" ]; then
        # No name: list available saves as a hint
        _has_saves=0
        if [ -d "$TX_SAVE_DIR" ]; then
            for _check in "$TX_SAVE_DIR"/*; do
                [ -f "$_check" ] && _has_saves=1 && break
            done
        fi
        if [ "$_has_saves" -eq 1 ]; then
            printf '%sSaved layouts:%s\n' "$BOLD" "$RESET"
            for _file in "$TX_SAVE_DIR"/*; do
                [ -f "$_file" ] || continue
                _s=$(basename "$_file")
                _panes=$(tail -n +2 "$_file" | wc -l | tr -d ' ')
                printf '  %s%s%s (%s panes)\n' "$CYAN" "$_s" "$RESET" "$_panes"
            done
            echo ""
            printf 'Usage: %stx load <name>%s\n' "$CYAN" "$RESET"
        else
            die "no saved layouts — use 'tx save <name>' inside tmux first"
        fi
        return
    fi

    _file="${TX_SAVE_DIR}/${1}"
    [ -f "$_file" ] || die "save '${1}' not found"

    _name="$1"
    _layout=$(head -1 "$_file")
    _pane_count=$(tail -n +2 "$_file" | wc -l | tr -d ' ')

    if ! in_tmux; then
        _first_dir=$(tail -n +2 "$_file" | head -1 | cut -d'|' -f1)

        # Remove existing session with same name
        tmux kill-session -t "$_name" 2>/dev/null || true

        tmux new-session -d -s "$_name" -c "$_first_dir"

        # Create remaining panes
        _i=2
        while [ "$_i" -le "$_pane_count" ]; do
            _pane_dir=$(tail -n +2 "$_file" | sed -n "${_i}p" | cut -d'|' -f1)
            tmux split-window -h -t "$_name" -c "$_pane_dir"
            tmux select-layout -t "$_name" even-horizontal
            _i=$(( _i + 1 ))
        done

        # Apply the exact saved layout
        tmux select-layout -t "$_name" "$_layout" 2>/dev/null || true

        # Send commands to each pane
        _pane_idx=0
        tail -n +2 "$_file" | while IFS='|' read -r _dir _cmd; do
            if [ -n "$_cmd" ]; then
                tmux send-keys -t "${_name}:0.${_pane_idx}" "$_cmd" Enter
            fi
            _pane_idx=$(( _pane_idx + 1 ))
        done

        tmux select-pane -t "${_name}:0.0"
        tmux attach-session -t "$_name"
    else
        _first_dir=$(tail -n +2 "$_file" | head -1 | cut -d'|' -f1)
        tmux new-window -n "$_name" -c "$_first_dir"

        _i=2
        while [ "$_i" -le "$_pane_count" ]; do
            _pane_dir=$(tail -n +2 "$_file" | sed -n "${_i}p" | cut -d'|' -f1)
            tmux split-window -h -c "$_pane_dir"
            tmux select-layout even-horizontal
            _i=$(( _i + 1 ))
        done

        tmux select-layout "$_layout" 2>/dev/null || true

        _pane_idx=0
        tail -n +2 "$_file" | while IFS='|' read -r _dir _cmd; do
            if [ -n "$_cmd" ]; then
                tmux send-keys -t "$_pane_idx" "$_cmd" Enter
            fi
            _pane_idx=$(( _pane_idx + 1 ))
        done

        tmux select-pane -t 0
        printf '  %s✓%s Loaded %s%s%s (%s panes)\n' "$GREEN" "$RESET" "$BOLD" "$_name" "$RESET" "$_pane_count"
    fi
}

# List all saved layouts
cmd_saves() {
    if [ ! -d "$TX_SAVE_DIR" ]; then
        echo "No saved layouts."
        return
    fi

    _found=0
    for _file in "$TX_SAVE_DIR"/*; do
        [ -f "$_file" ] || continue
        _found=1
        _s=$(basename "$_file")
        _panes=$(tail -n +2 "$_file" | wc -l | tr -d ' ')

        printf '  %s%s%s (%s panes)\n' "$CYAN" "$_s" "$RESET" "$_panes"
        tail -n +2 "$_file" | while IFS='|' read -r _dir _cmd; do
            if [ -n "$_cmd" ]; then
                printf '    %s%s%s  %s\n' "$DIM" "$_dir" "$RESET" "$_cmd"
            else
                printf '    %s%s%s\n' "$DIM" "$_dir" "$RESET"
            fi
        done
    done

    if [ "$_found" -eq 0 ]; then
        echo "No saved layouts."
    fi
}

# Remove a saved layout
cmd_rm() {
    [ -n "$1" ] || die "usage: tx rm <name>"
    _file="${TX_SAVE_DIR}/${1}"
    [ -f "$_file" ] || die "save '${1}' not found"
    rm "$_file"
    printf '  %s✓%s Removed %s%s%s\n' "$GREEN" "$RESET" "$BOLD" "$1" "$RESET"
}

# Window commands

# Create a new window, optionally with a name
cmd_win() {
    in_tmux || die "not in tmux — start a session first: tx new"
    if [ -n "$1" ]; then
        tmux new-window -n "$1"
    else
        tmux new-window
    fi
}

# List all windows
cmd_wins() {
    if in_tmux; then
        tmux list-windows -F '#I|#W|#{window_active}' | while IFS='|' read -r _i _w _a; do
            if [ "$_a" = "1" ]; then
                printf '  %s%s: %s%s (active)\n' "$CYAN" "$_i" "$_w" "$RESET"
            else
                printf '  %s: %s\n' "$_i" "$_w"
            fi
        done
    else
        tmux list-windows -a -F '#S:#I: #W' 2>/dev/null || echo "No sessions."
    fi
}

# Switch to the next window
cmd_next() {
    in_tmux || die "not in tmux"
    tmux next-window
}

# Switch to the previous window
cmd_prev() {
    in_tmux || die "not in tmux"
    tmux previous-window
}

# Rename the current window
cmd_rename() {
    [ -n "$1" ] || die "usage: tx rename <name>"
    in_tmux || die "not in tmux"
    tmux rename-window "$1"
}

# Version and update

cmd_version() {
    echo "tx ${TX_VERSION}"
}

# Self-update by downloading the latest tx from GitHub
cmd_update() {
    _raw="https://raw.githubusercontent.com/Harsh-2002/tx/main/tx"
    _self=$(command -v tx 2>/dev/null || echo "$0")

    # Resolve to absolute path
    case "$_self" in
        /*) ;;
        *)  _self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")" ;;
    esac

    [ -w "$_self" ] || die "cannot write to $_self — try: sudo tx update"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$_raw" > "$_self.tmp"
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- "$_raw" > "$_self.tmp"
    else
        die "need curl or wget to update"
    fi

    chmod +x "$_self.tmp"
    mv "$_self.tmp" "$_self"

    _new_ver=$("$_self" --version 2>/dev/null || echo "unknown")
    printf '  %s✓%s Updated to %s%s%s\n' "$GREEN" "$RESET" "$BOLD" "$_new_ver" "$RESET"
}

# Help

# Show all commands or detailed help for a specific command
cmd_help() {
    if [ -n "$1" ]; then
        cmd_help_detail "$1"
        return
    fi

    cat <<EOF
${BOLD}tx${RESET} — a dead-simple tmux wrapper

${BOLD}SESSIONS${RESET}
  ${CYAN}tx${RESET}                      Smart default (attach/create/list)
  ${CYAN}tx new${RESET} [name]           New session (auto-names if omitted)
  ${CYAN}tx ls${RESET}                   List sessions
  ${CYAN}tx a${RESET} [name]             Attach to session
  ${CYAN}tx detach${RESET}               Detach from current session
  ${CYAN}tx kill${RESET} [name]          Kill session

${BOLD}PANES${RESET}
  ${CYAN}tx split${RESET}                Split side-by-side (left/right)
  ${CYAN}tx vsplit${RESET}               Split top/bottom
  ${CYAN}tx pane${RESET} <n>             Switch to pane N (1-indexed)
  ${CYAN}tx close${RESET}                Close current pane
  ${CYAN}tx resize${RESET} <dir> [n]     Resize pane (left/right/up/down/even)
  ${CYAN}tx swap${RESET} <n>             Swap current pane with pane N
  ${CYAN}tx full${RESET}                 Toggle fullscreen on current pane

${BOLD}SEND${RESET}
  ${CYAN}tx send${RESET} <n> '<cmd>'     Run command in pane N
  ${CYAN}tx send-all${RESET} '<cmd>'      Broadcast command to all panes

${BOLD}LAYOUT${RESET}
  ${CYAN}tx layout${RESET} <n>           Create N columns (horizontal)
  ${CYAN}tx layout${RESET} <n> -v        Create N rows (vertical)
  ${CYAN}tx layout${RESET} <n> grid      Create N panes in a grid
  ${CYAN}tx layout${RESET} <n> [cmds..]  Create panes and run commands in each

${BOLD}SAVE / LOAD${RESET}
  ${CYAN}tx save${RESET} [name]          Save current layout + commands
  ${CYAN}tx load${RESET} <name>          Restore a saved layout
  ${CYAN}tx saves${RESET}                List saved layouts
  ${CYAN}tx rm${RESET} <name>            Delete a saved layout

${BOLD}WINDOWS${RESET}
  ${CYAN}tx win${RESET} [name]           New window
  ${CYAN}tx wins${RESET}                 List windows
  ${CYAN}tx next${RESET}                 Next window
  ${CYAN}tx prev${RESET}                 Previous window
  ${CYAN}tx rename${RESET} <name>        Rename current window

${BOLD}OTHER${RESET}
  ${CYAN}tx help${RESET}                 Show this help
